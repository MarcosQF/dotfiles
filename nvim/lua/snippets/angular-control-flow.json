{
  "@for loop": {
    "prefix": "afor",
    "body": [
      "@for (${1:item} of ${2:items()}; track ${3:$1.id}) {",
      "\t$0",
      "}"
    ],
    "description": "Angular @for control block"
  },
  "@if block": {
    "prefix": "aif",
    "body": [
      "@if (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "Angular @if control block"
  },
  "@empty block": {
    "prefix": "aem",
    "body": [
      "@empty {",
      "\t$0",
      "}"
    ],
    "description": "Angular @empty block"
  }
}
